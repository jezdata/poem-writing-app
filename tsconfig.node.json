{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": [
    "vite.config.ts",
    "server/**/*.ts",
    "src/lib/constants.ts",
    "src/lib/prompts.ts",
    "src/lib/sanitize.ts",
    "src/lib/types.ts",
    "src/lib/validation.ts"
  ]
}
